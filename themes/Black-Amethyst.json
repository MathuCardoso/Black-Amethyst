    "name": "Black Amethyst",
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "class.declaration": { "foreground": "#a85ff1" },
        "class.decorator": { "foreground": "#d46ec0" },
        "enumMember": { "foreground": "#a85ff1" },
        "meta.decorator": { "foreground": "#d46ec0" },
        "namespace": { "foreground": "#11B7D4" },
        "parameter": { "foreground": "#d46ec0" },
        "property": { "foreground": "#d4770c" },
        "property.declaration": { "foreground": "#bec6d0" },
        "variable": { "foreground": "#c62f52" },
        "variable.defaultLibrary": { "foreground": "#38c7bd" }
    },

    "tokenColors": [
        {
            "scope": [
                "entity.name.type.namespace.php",
                "meta.namespace.php",
                "source.php",
                "meta.embedded.block.php",
                "text.html.php",
                "support.other.namespace.php",
                "meta.use.php",
                "keyword.operator.key.php",
                "keyword.operator.assignment.php"
            ],
            "settings": {
                "foreground": "#ff7300"
            }
        },
        {
            "scope": [
                "support.class.php",
                "meta.use.php",
                "source.php",
                "meta.embedded.block.php",
                "entity.name.type.class.php",
                "meta.class.php",
                "punctuation.definition.variable.php",
                "punctuation.section.embedded.begin.php",
                "punctuation.section.embedded.end.php",
                "punctuation.section.embedded.end.php source.php",
                "entity.other.attribute-name.class.css",
                "variable.key.dotenv"
            ],
            "settings": {
                "foreground": "#bd1df7"
            }
        },
        {
            "scope": [
                "punctuation.definition.variable.php",
                "meta.tag.structure.div.start.html entity.name.tag.html",
                "meta.tag.structure.div.end.html entity.name.tag.html",
                "constant.numeric.css"
            ],
            "settings": {
                "foreground": "#00ffd5"
            }
        },
        {
            "scope": ["string.quoted.double.php"],
            "settings": {
                "foreground": "#9417c2"
            }
        },
        {
            "name": "ASPAS",
            "scope": [
                "punctuation.terminator.expression.php",
                "punctuation.definition.string.begin.php",
